client
dev tun
proto %HOST_TUN_PROTOCOL%
resolv-retry infinite
nobind
persist-key
persist-tun
data-ciphers AES-128-GCM:AES-256-GCM
data-ciphers-fallback AES-128-GCM
auth SHA256
verb 3
tls-client
tls-version-min 1.2
key-direction 1
remote-cert-tls server

sndbuf 0
rcvbuf 0

tun-mtu 1500
mssfix 1400
# fragment 0 # Errore valore inferiore a 68 byte

auth-nocache
pull-filter ignore redirect-gateway
pull-filter ignore "dhcp-option DNS"

route-nopull
route 10.9.12.0 255.255.255.0